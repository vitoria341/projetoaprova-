@page "/telaprincipal"

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Preparação ENEM</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <div class="container">

        <h1>
            Prepare-se para o <span>ENEM</span> e Vestibulares
        </h1>

        <p class="descricao">
            Metodologia comprovada, professores especializados e conteúdo completo
            para você conquistar a aprovação dos seus sonhos.
        </p>

        <div class="cards">

            <div class="card">
                <img src="https://img.magnific.com/fotos-gratis/tabuleiro-com-inscricoes-de-formulas-e-calculos-cientificos_1150-19413.jpg?semt=ais_hybrid&w=740&q=80" alt="Matemática">
                <div class="conteudo">
                    <h2>Matemática</h2>
                    <strong>Principais tópicos:</strong>
                    <ul>
                        <li>Funções e Equações</li>
                        <li>Geometria Plana e Espacial</li>
                        <li>Estatística e Probabilidade</li>
                        <li>Matemática Financeira</li>
                    </ul>
                </div>
            </div>

            <div class="card">
                <img src="https://static.todamateria.com.br/upload/li/ng/linguagens-codigos-e-suas-tecnologias-og.jpg?class=ogImageWide" alt="Linguagens">
                <div class="conteudo">
                    <h2>Linguagens</h2>
                    <strong>Principais tópicos:</strong>
                    <ul>
                        <li>Interpretação de textos</li>
                        <li>Gêneros textuais</li>
                        <li>Figuras de linguagem</li>
                        <li>Funções da linguagem</li>
                        <li>Variação linguística</li>
                    </ul>
                </div>
            </div>

            <div class="card">
                <img src="https://conteudo.solutudo.com.br/wp-content/uploads/2019/10/ciencias-da-natureza-e-suas-tecnologias-og-1.jpg" alt="Natureza">
                <div class="conteudo">
                    <h2>Ciências da Natureza</h2>
                    <strong>Principais tópicos:</strong>
                    <ul>
                        <li>Ecologia</li>
                        <li>Genética</li>
                        <li>Citologia</li>
                        <li>Química</li>
                        <li>Física</li>
                    </ul>
                </div>
            </div>

            <div class="card">
                <img src="https://static.todamateria.com.br/upload/ci/en/ciencias-humanas-e-suas-tecnologias-og.jpg?class=ogImageWide" alt="Humanas">
                <div class="conteudo">
                    <h2>Ciências Humanas</h2>
                    <strong>Principais tópicos:</strong>
                    <ul>
                        <li>História</li>
                        <li>Geografia</li>
                        <li>Filosofia</li>
                        <li>Sociologia</li>
                    </ul>
                </div>
            </div>

            <div class="card">
                <img src="https://conversadeportugues.com.br/wp-content/uploads/2022/09/REDACAO-ENEM-1.jpg" alt="Redação">
                <div class="conteudo">
                    <h2>Redação</h2>
                    <strong>Principais tópicos:</strong>
                    <ul>
                        <li>Estrutura dissertativa</li>
                        <li>Tese e argumentos</li>
                        <li>Coesão</li>
                        <li>Repertório sociocultural</li>
                        <li>Proposta de intervenção</li>
                    </ul>
                </div>
            </div>

        </div>

    </div>

</body>
</html>